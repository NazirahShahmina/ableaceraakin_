//css

/* Body class to show chat */
body.chat-open {
    .chat-window {
        display: flex;
    }
}

/* Chat toggle button */
.chat-button {
    position: absolute;
    bottom: 40px; /* slightly higher for smaller chatbox */
    right: 15px;
    z-index: 998;
    background-color: var(--black);
    color: white;
    height: 60px; /* smaller button */
    width: 60px;
    border-radius: 50%;
    display: flex;
    justify-content: center;
    align-items: center;
    cursor: pointer;

    img {
        width: 35px; /* smaller icon */
    }

    &:hover {
        box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
    }
}

/* Chatbox window */
.chat-window {

    * {
        font-family: "Raleway", sans-serif;
    }

    display: none;
    box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
    background-color: white;
    border-radius: 20px;
    position: absolute;
    z-index: 999;
    bottom: 110px; /* slightly higher to avoid overlapping button */
    right: 20px;
    height: 500px; /* slightly shorter */
    width: 320px;  /* slightly narrower */
    max-width: 90%; /* responsive */
    flex-direction: column;
    justify-content: space-between;

    /* Add top padding to prevent content from being cut off */
    padding-top: 40px;

    .close {
        position: absolute; /* stay on top */
        top: 0;
        left: 0;
        width: 100%;
        border: none;
        padding: 8px 0;
        background-color: var(--black);
        color: white;
        border-radius: 20px 20px 0 0;
        cursor: pointer;
        z-index: 10;
    }

    .chat {
        flex: 1;
        padding: 0 8px;
        overflow-y: scroll;

        p {
            border-radius: 20px;
            width: 80%;
            margin: 8px 0;
            font-size: 16px;
            padding: 16px;
        }

        div.model {
            p {
                background-color: var(--grey);
            }
        }

        div.user {
            display: flex;
            justify-content: flex-end;

            p {
                background-color: var(--blue);
                color: white;
            }
        }

        div.error {
            p {
                font-size: 14px;
                text-align: center;
                color: red;
            }
        }
    }

    .input-area {
        height: 70px;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 0 8px;
        border-top: 1px solid lightgray;

        input {
            height: 40px;
            flex: 1;
            border: none;
            background-color: var(--grey);
            border-radius: 20px;
            padding-left: 20px;
            font-size: 16px;
        }

        button {
            height: 40px;
            width: 40px;
            border-radius: 50%;
            border: none;
            margin-left: 12px;
            background-color: var(--blue);
            color: white;
            display: flex;
            justify-content: center;
            align-items: center;
            cursor: pointer;

            img {
                width: 18px;
            }

            &:hover {
                box-shadow: rgba(0, 0, 0, 0.24) 0px 3px 8px;
            }
        }
    }
}

/* Loader animation */
.loader {
    width: 40px;
    opacity: 0.4;
    aspect-ratio: 4;
    background: radial-gradient(circle closest-side,#000 90%,#0000) 0/calc(100%/3) 100% space;
    clip-path: inset(0 100% 0 0);
    animation: l1 1.5s steps(4) infinite;
}
@keyframes l1 {
    to { clip-path: inset(0 -34% 0 0); }
}

/* Responsive tweak for mobile screens */
@media (max-width: 480px) {
    .chat-window {
        width: 90%;
        height: 450px;
        bottom: 100px;
        right: 5%;
        padding-top: 35px;
    }

    .chat-button {
        height: 50px;
        width: 50px;
        img {
            width: 28px;
        }
    }
}